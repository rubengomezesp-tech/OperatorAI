/**
 * Agent tools — invoked by Claude directly inside a chat turn so the user
 * receives imagery, video, file analysis, and knowledge answers inline.
 * No tab switching.
 *
 * Each tool has:
 *   - a JSON-schema spec for Claude
 *   - an execute() that runs server-side reusing the same database writes
 *     your /api/images/generate, /api/video/generate endpoints already do.
 */
import type { SupabaseClient } from '@supabase/supabase-js';
import type { ToolKind } from '@/lib/chat/types';

export interface ToolSpec {
  name: ToolKind;
  description: string;
  input_schema: Record<string, unknown>;
}

export const TOOL_SPECS: ToolSpec[] = [
  {
    name: 'image',
    description:
      'Generate a premium, on-brand image from a text prompt. Use when the user asks for an image, visual, product shot, photo, illustration, mock-up, or picture. Returns image URLs shown inline in the chat. Takes about 6 seconds.',
    input_schema: {
      type: 'object',
      properties: {
        prompt: {
          type: 'string',
          description: 'Detailed description: subject, style, lighting, mood. If the user is terse ("shoes image"), expand it thoughtfully using the brand profile in context.',
        },
        preset: {
          type: 'string',
          enum: ['editorial', 'product', 'lifestyle', 'abstract', 'minimal'],
          description: 'Visual preset that guides style. Default editorial.',
        },
        aspect_ratio: {
          type: 'string',
          enum: ['1:1', '16:9', '9:16', '4:3', '3:4'],
          description: 'Image aspect ratio. Default 1:1 unless the user specifies a channel (Story = 9:16, YouTube thumbnail = 16:9, etc.).',
        },
      },
      required: ['prompt'],
    },
  },
  {
    name: 'video',
    description:
      'Generate a short cinematic video (~4 seconds) from a text prompt. Use when the user asks for a video, clip, animation, motion, or moving visual. Takes ~60-90 seconds to render. Returns a video URL shown inline.',
    input_schema: {
      type: 'object',
      properties: {
        prompt: {
          type: 'string',
          description: 'Scene description including subject, camera motion, mood.',
        },
        duration: {
          type: 'number',
          enum: [4, 8],
          description: 'Video duration in seconds. Default 4.',
        },
      },
      required: ['prompt'],
    },
  },
  {
    name: 'file_analysis',
    description:
      "Analyze a spreadsheet, CSV, JSON, or document the user previously uploaded in Files & Analysis. Use when the user asks a question about their own data. If the user has not told you which file, ask them first — do NOT guess file IDs.",
    input_schema: {
      type: 'object',
      properties: {
        file_id: { type: 'string', description: 'ID of the previously uploaded file.' },
        question: { type: 'string', description: 'The question to answer about the file.' },
      },
      required: ['file_id', 'question'],
    },
  },
  {
    name: 'knowledge_search',
    description:
      "Search the user's Knowledge base (PDFs, brand docs, internal guides) and return a synthesized answer with sources. Use when the user asks something specific about their own written materials.",
    input_schema: {
      type: 'object',
      properties: {
        query: { type: 'string', description: 'What to look up in the knowledge base.' },
      },
      required: ['query'],
    },
  },
];

export interface ToolContext {
  svc: SupabaseClient;
  orgId: string;
  userId: string;
  assistantId: string;
  signal?: AbortSignal;
}

export interface ToolResult {
  ok: boolean;
  result?: {
    urls?: string[];
    videoUrl?: string;
    thumbnailUrl?: string;
    text?: string;
    sources?: Array<{ title: string; id: string }>;
  };
  error?: string;
}

export async function executeTool(
  name: ToolKind,
  input: Record<string, unknown>,
  ctx: ToolContext,
): Promise<ToolResult> {
  try {
    switch (name) {
      case 'image': return await execImage(input, ctx);
      case 'video': return await execVideo(input, ctx);
      case 'file_analysis': return await execFileAnalysis(input, ctx);
      case 'knowledge_search': return await execKnowledgeSearch(input, ctx);
      default: return { ok: false, error: 'Unknown tool: ' + name };
    }
  } catch (e) {
    const msg = e instanceof Error ? e.message : 'Tool execution failed';
    console.error('[tools.execute]', name, msg);
    return { ok: false, error: msg };
  }
}

// ── image ──────────────────────────────────────────────────────────
async function execImage(
  input: Record<string, unknown>,
  ctx: ToolContext,
): Promise<ToolResult> {
  const prompt = String(input.prompt ?? '').trim();
  const preset = (input.preset as string) ?? 'editorial';
  const aspect = (input.aspect_ratio as string) ?? '1:1';
  if (!prompt) return { ok: false, error: 'Empty prompt' };

  // Re-use your Flux client
  const mod = await import('@/features/image-studio/server/flux-client');
  // Common export name patterns — try the most likely one
  const fn =
    (mod as { generateImage?: (a: unknown) => Promise<unknown> }).generateImage ??
    (mod as { generateFluxImage?: (a: unknown) => Promise<unknown> }).generateFluxImage ??
    (mod as { default?: (a: unknown) => Promise<unknown> }).default;

  if (typeof fn !== 'function') {
    return { ok: false, error: 'generateImage not exported by flux-client' };
  }

  const raw = (await fn({
    svc: ctx.svc,
    orgId: ctx.orgId,
    userId: ctx.userId,
    prompt,
    preset,
    aspectRatio: aspect,
    enhance: true,
  })) as { urls?: string[]; url?: string; display_urls?: string[] } | null;

  const urls =
    raw?.urls ??
    raw?.display_urls ??
    (raw?.url ? [raw.url] : []);
  if (!urls || urls.length === 0) {
    return { ok: false, error: 'No image returned' };
  }
  return { ok: true, result: { urls } };
}

// ── video ──────────────────────────────────────────────────────────
async function execVideo(
  input: Record<string, unknown>,
  ctx: ToolContext,
): Promise<ToolResult> {
  const prompt = String(input.prompt ?? '').trim();
  const duration = Number(input.duration ?? 4);
  if (!prompt) return { ok: false, error: 'Empty prompt' };

  const mod = await import('@/features/video/server/veo-client');
  const fn =
    (mod as { generateVideo?: (a: unknown) => Promise<unknown> }).generateVideo ??
    (mod as { default?: (a: unknown) => Promise<unknown> }).default;

  if (typeof fn !== 'function') {
    return { ok: false, error: 'generateVideo not exported by veo-client' };
  }

  const raw = (await fn({
    svc: ctx.svc,
    orgId: ctx.orgId,
    userId: ctx.userId,
    prompt,
    duration,
  })) as { videoUrl?: string; url?: string; thumbnailUrl?: string; thumbnail_url?: string } | null;

  const videoUrl = raw?.videoUrl ?? raw?.url;
  const thumbnailUrl = raw?.thumbnailUrl ?? raw?.thumbnail_url;
  if (!videoUrl) return { ok: false, error: 'Video generation returned no URL' };
  return { ok: true, result: { videoUrl, thumbnailUrl } };
}

// ── file analysis ──────────────────────────────────────────────────
async function execFileAnalysis(
  input: Record<string, unknown>,
  ctx: ToolContext,
): Promise<ToolResult> {
  const fileId = String(input.file_id ?? '');
  const question = String(input.question ?? '');
  if (!fileId || !question) return { ok: false, error: 'Missing file_id or question' };

  // Validate the file belongs to this org before doing anything else
  const { data: fileRow } = await ctx.svc
    .from('files')
    .select('id, name')
    .eq('id', fileId)
    .eq('org_id', ctx.orgId)
    .maybeSingle();
  if (!fileRow) return { ok: false, error: "File not found in this workspace" };

  // Call the existing analyze endpoint server-to-server
  const origin = process.env.NEXT_PUBLIC_APP_URL ?? 'http://localhost:3000';
  const res = await fetch(origin + '/api/files/analyze', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-internal-agent': process.env.INTERNAL_AGENT_SECRET ?? '',
      'x-internal-org': ctx.orgId,
      'x-internal-user': ctx.userId,
    },
    body: JSON.stringify({ fileId, question }),
    signal: ctx.signal,
  }).catch((e) => {
    throw new Error('Could not reach file analysis: ' + (e as Error).message);
  });
  const body = (await res.json().catch(() => ({}))) as { answer?: string; error?: string };
  if (!res.ok) return { ok: false, error: body.error ?? 'Analysis failed' };
  return { ok: true, result: { text: String(body.answer ?? '') } };
}

// ── knowledge search ───────────────────────────────────────────────
async function execKnowledgeSearch(
  input: Record<string, unknown>,
  ctx: ToolContext,
): Promise<ToolResult> {
  const query = String(input.query ?? '').trim();
  if (!query) return { ok: false, error: 'Empty query' };

  const { embedOne } = await import('@/lib/rag/embeddings');
  const { retrieveChunks, formatKnowledgeBlock } = await import('@/lib/rag/retrieve');

  const queryEmbedding = await embedOne(query);

  const chunks = await retrieveChunks({
    svc: ctx.svc,
    orgId: ctx.orgId,
    assistantId: ctx.assistantId,
    query,
    queryEmbedding,
    topK: 6,
  });

  if (chunks.length === 0) {
    return { ok: true, result: { text: 'No matching documents found in the knowledge base.' } };
  }

  const text = formatKnowledgeBlock(chunks);
  const sources = chunks.map((c) => ({
    title: c.source ?? 'Document',
    id: c.document_id,
  }));
  return { ok: true, result: { text, sources } };
}
