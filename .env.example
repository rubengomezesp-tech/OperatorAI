# Operator Coach / Coding Runtime (OpenAI-compatible model server)
# In local development this can be LM Studio on your Mac. In production, do
# not use localhost unless OperatorAI itself is running on that same Mac.
OPERATOR_COACH_URL=http://localhost:1234
OPERATOR_COACH_MODEL=operator-qwen14b
OPERATOR_COACH_API_KEY=
OPERATOR_COACH_AUTH_HEADER=Authorization

# Backwards-compatible aliases used by older code/config.
LOCAL_OPERATOR_URL=http://localhost:1234
LOCAL_OPERATOR_MODEL=operator-qwen14b
LOCAL_OPERATOR_API_KEY=

CODING_RUNTIME_ENABLED=false
CODING_RUNTIME_WORKSPACE_ROOT=

DEFAULT_TEXT_PROVIDER=openai
DEFAULT_IMAGE_PROVIDER=replicate
DEFAULT_STT_PROVIDER=openai-whisper
DEFAULT_TTS_PROVIDER=openai-tts
DEFAULT_EMBEDDINGS_PROVIDER=openai

LANGFUSE_PUBLIC_KEY=
