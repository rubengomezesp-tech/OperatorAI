# Operator Coach / local Qwen model server.
# Local dev can use LM Studio on your Mac. Production must use a public tunnel
# or stable bridge URL, not localhost.
OPERATOR_COACH_URL=http://localhost:1234
OPERATOR_COACH_MODEL=operator-qwen14b
OPERATOR_COACH_API_KEY=
# Alias used by the local secure proxy script. Either this or
# OPERATOR_COACH_API_KEY can hold the bearer token.
OPERATOR_COACH_PROXY_TOKEN=
OPERATOR_COACH_AUTH_HEADER=Authorization
OPERATOR_COACH_TIMEOUT_MS=10000
OPERATOR_CODING_WORKSPACE=/Users/rubenymarina/Development/OperatorAI

# Backwards-compatible aliases used by older local scripts/config.
LOCAL_OPERATOR_URL=http://localhost:1234
LOCAL_OPERATOR_MODEL=operator-qwen14b
LOCAL_OPERATOR_API_KEY=

