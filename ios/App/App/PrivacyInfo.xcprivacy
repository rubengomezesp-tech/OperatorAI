<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Operator AI — App Privacy Manifest

		Required by Apple since May 1, 2024.
		Without this file, App Store will reject the build.

		Documentation:
		https://developer.apple.com/documentation/bundleresources/privacy_manifest_files

		This manifest declares:
		1. What data we collect from users (NSPrivacyCollectedDataTypes)
		2. Tracking domains (NSPrivacyTracking) — we don't track
		3. Required Reason APIs we use (NSPrivacyAccessedAPITypes)
	-->

	<!--
		Section 1: Data tracking
		"Tracking" = linking user data with third-party data for advertising.
		Operator AI does NOT do this.
	-->
	<key>NSPrivacyTracking</key>
	<false/>

	<!--
		Section 2: Tracking domains
		Empty because we don't track. If you ever add Meta Pixel,
		Google Analytics with ad personalization, etc., they go here.
	-->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!--
		Section 3: Data we collect (linked to user identity)
		For each type, declare:
		  - what (NSPrivacyCollectedDataType)
		  - is it linked to user (NSPrivacyCollectedDataTypeLinked)
		  - is it used for tracking (NSPrivacyCollectedDataTypeTracking)
		  - purposes (NSPrivacyCollectedDataTypePurposes)

		Purposes (Apple-defined codes):
		  ANALYTICS         — Analytics
		  APP_FUNCTIONALITY — App Functionality (e.g. authentication)
		  PRODUCT_PERSONALIZATION — Personalize content shown to user
		  DEVELOPER_ADVERTISING   — First-party advertising
		  THIRD_PARTY_ADVERTISING — Third-party advertising
		  OTHER_PURPOSES    — Other purposes
	-->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- Email address (for account, support, billing) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeEmailAddress</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

		<!-- Name (for account / billing) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeName</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

		<!-- User ID (Supabase auth.uid) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

		<!-- Photos / images user uploads -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePhotosorVideos</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
				<string>NSPrivacyCollectedDataTypePurposeProductPersonalization</string>
			</array>
		</dict>

		<!-- Audio (voice recordings for transcription) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeAudioData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

		<!-- User content (chat messages, prompts, generated content) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherUserContent</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
				<string>NSPrivacyCollectedDataTypePurposeProductPersonalization</string>
			</array>
		</dict>

		<!-- Crash data (Sentry) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeCrashData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>

		<!-- Device ID (for push tokens) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>

		<!-- Payment info (handled by RevenueCat / Apple — not stored by us) -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePurchaseHistory</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>

	<!--
		Section 4: Required Reason APIs
		Apple requires a declared reason for using certain APIs that
		could be used for fingerprinting. Each API has a list of
		valid reasons (see Apple docs for the full list).
	-->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!-- File timestamps (used by image saving, file access) -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- C617.1 = Inside the app, read or write files in the app container -->
				<string>C617.1</string>
			</array>
		</dict>

		<!-- User defaults (UserDefaults) — used by Capacitor / iOS -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1 = Read/write same as default access; not derived from user identifiers -->
				<string>CA92.1</string>
			</array>
		</dict>

		<!-- System boot time — Capacitor uses for some platform calls -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategorySystemBootTime</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- 35F9.1 = Measure time elapsed between events that occur within the app, or between app launches -->
				<string>35F9.1</string>
			</array>
		</dict>

		<!-- Disk space — for upload size validation, cache management -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryDiskSpace</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- E174.1 = Display disk space info to user, for app's purposes -->
				<string>E174.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
