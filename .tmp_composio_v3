import 'server-only';
import { Composio } from '@composio/core';
import { serverEnv } from '@/lib/env';
import { getAuthConfigIdForProvider } from '@/features/integrations/data/catalog';

/**
 * 🔌 COMPOSIO CLIENT v3
 *
 * Migrated from v1 (deprecated 2026-05-08) to v3 SDK @composio/core.
 *
 * Each provider has its auth_config_id stored in env vars:
 *   - COMPOSIO_AUTH_CONFIG_GMAIL
 *   - COMPOSIO_AUTH_CONFIG_GCAL
 *   - COMPOSIO_AUTH_CONFIG_GDRIVE
 *   - COMPOSIO_AUTH_CONFIG_SLACK
 */

export interface ComposioConnection {
  connectedAccountId: string;
  redirectUrl: string;
}

export interface ComposioToolResult {
  successful: boolean;
  data?: unknown;
  error?: string;
}

let _client: Composio | null = null;

function getClient(): Composio {
  if (_client) return _client;
  const apiKey = (serverEnv as unknown as Record<string, string | undefined>).COMPOSIO_API_KEY;
  if (!apiKey) throw new Error('COMPOSIO_API_KEY not configured');
  _client = new Composio({ apiKey });
  return _client;
}

function getAuthConfigId(providerId: string): string {
  const envVarName = getAuthConfigIdForProvider(providerId);
  if (!envVarName) {
    throw new Error(`No auth config env var defined for provider: ${providerId}`);
  }
  const id = (serverEnv as unknown as Record<string, string | undefined>)[envVarName];
  if (!id) {
    throw new Error(`${envVarName} not configured. Create auth config in Composio dashboard.`);
  }
  if (!id.startsWith('ac_')) {
    throw new Error(`Invalid auth config id format for ${envVarName} (expected 'ac_...')`);
  }
  return id;
}

export async function initiateConnection(params: {
  userId: string;
  providerId: string;
  callbackUrl: string;
  allowMultiple?: boolean;
}): Promise<ComposioConnection> {
  const composio = getClient();
  const authConfigId = getAuthConfigId(params.providerId);

  const connRequest = await composio.connectedAccounts.link(
    params.userId,
    authConfigId,
    {
      callbackUrl: params.callbackUrl,
      ...(params.allowMultiple ? { allowMultiple: true } : {}),
    },
  );

  type LinkResp = { id: string; redirectUrl?: string | null };
  const r = connRequest as unknown as LinkResp;

  if (!r.redirectUrl) {
    throw new Error(
      'Composio did not return redirectUrl. Auth config may not be OAuth-redirectable.',
    );
  }

  return {
    connectedAccountId: r.id,
    redirectUrl: r.redirectUrl,
  };
}

export async function getConnectionStatus(connectedAccountId: string): Promise<{
  status: string;
  toolkitSlug: string;
}> {
  const composio = getClient();
  const account = await composio.connectedAccounts.get(connectedAccountId);
  return {
    status: (account as unknown as { status: string }).status,
    toolkitSlug: (account as unknown as { toolkit?: { slug?: string } }).toolkit?.slug ?? '',
  };
}

export async function executeTool(params: {
  userId: string;
  toolSlug: string;
  input: Record<string, unknown>;
}): Promise<ComposioToolResult> {
  const composio = getClient();

  try {
    const result = await composio.tools.execute(params.toolSlug, {
      userId: params.userId,
      arguments: params.input,
    });
    type ExecResult = { successful?: boolean; data?: unknown; error?: string };
    const r = result as unknown as ExecResult;
    return {
      successful: r.successful ?? true,
      data: r.data,
      error: r.error,
    };
  } catch (e) {
    return {
      successful: false,
      error: e instanceof Error ? e.message : 'Tool execution failed',
    };
  }
}

export async function disconnectAccount(connectedAccountId: string): Promise<void> {
  const composio = getClient();
  await composio.connectedAccounts.delete(connectedAccountId);
}
